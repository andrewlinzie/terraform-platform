aws_region = "us-east-2"

project_name = "ai-cloud-platform"
environment  = "staging"

vpc_cidr = "10.1.0.0/16"

public_subnet_cidrs = [
  "10.1.1.0/24",
  "10.1.2.0/24"
]

private_subnet_cidrs = [
  "10.1.11.0/24",
  "10.1.12.0/24"
]

availability_zones = [
  "us-east-2a",
  "us-east-2b"
]

# Replace with your public IP (e.g., 203.0.113.10/32)
trusted_cidr_blocks = [
  "YOUR_PUBLIC_IP/32"
]

cluster_name       = "ai-cloud-platform-staging-eks"
kubernetes_version = "1.33"

node_group_name     = "ai-cloud-platform-staging-node-group"
node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 4

eks_node_ssh_key_name = null

cms_instance_type = "t3.medium"
cms_key_name      = "ai-cloud-platform-staging-cms-key"

# Paste your SSH public key (e.g., contents of ~/.ssh/id_rsa.pub)
cms_public_key    = "YOUR_SSH_PUBLIC_KEY"